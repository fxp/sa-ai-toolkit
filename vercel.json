{
  "buildCommand": null,
  "outputDirectory": ".",
  "framework": null,
  "rewrites": [
    { "source": "/org-uplift", "destination": "/demos/demo-metr-org-uplift/index.html" },
    { "source": "/org-uplift/(.*)", "destination": "/demos/demo-metr-org-uplift/$1" },
    { "source": "/ceo-dashboard", "destination": "/demos/orchestrator/ceo-dashboard.html" },
    { "source": "/autoresearch", "destination": "/demos/bonus-autoresearch/website/index.html" },
    { "source": "/autoresearch/(.*)", "destination": "/demos/bonus-autoresearch/website/$1" },
    { "source": "/", "destination": "/docs/index.html" },
    { "source": "/((?!demos|docs).*)", "destination": "/docs/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
